# ============================================================================
# Job Application Tracker — sample configuration
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# The .env file is gitignored; NEVER commit it.
# ============================================================================

# --- LLM provider selection: gemini | openrouter | anthropic ---
LLM_PROVIDER=gemini

# --- Gemini (free tier; https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your-gemini-api-key
# gemini-3.1-flash-lite offers 500 requests/day on the free tier.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- OpenRouter (fallback; https://openrouter.ai/keys) ---
OPENROUTER_API_KEY=your-openrouter-api-key
# Models with the ":free" suffix are free.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Anthropic (optional; https://console.anthropic.com) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model to use. Haiku is recommended for cheap/fast classification.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Gmail API / OAuth ---
# OAuth client secret file downloaded from Google Cloud (Desktop app type).
GMAIL_CREDENTIALS_FILE=credentials.json
# Refresh token file produced by the first OAuth flow (poller --auth).
GMAIL_TOKEN_FILE=token.json
# Which mails to fetch. Gmail search query (https://support.google.com/mail/answer/7190).
# e.g. last 30 days. Spam/Trash are excluded by default.
GMAIL_QUERY=newer_than:30d
# Maximum number of mails fetched per run (pagination is supported).
GMAIL_MAX_RESULTS=500

# --- Database ---
# SQLite file path. Pure-Go driver (modernc.org/sqlite), no CGO needed.
DB_PATH=job_tracker.db

# --- Notifications ---
# NOTIFIER: telegram | ntfy | none. When empty it is auto-selected: telegram if
# its token is set, else ntfy if its topic is set, else none.
NOTIFIER=
# Telegram setup: create a bot via @BotFather (gives the token), send your bot
# one message, then read your chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates ("chat":{"id":...}).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# ntfy topic URL for push notifications to your phone. Pick a hard-to-guess name!
NTFY_TOPIC=

# --- Poller behavior ---
# Real-time mode: Gmail history check interval (the check is nearly free,
# so a short interval gives near-instant pickup). Go duration format.
POLL_INTERVAL=45s
# Classifications below this confidence are not written to the DB.
CONFIDENCE_THRESHOLD=0.6

# --- Pre-filter (cheap screening before the LLM) ---
# keywords: keyword/domain string checks only (default, completely free).
# hybrid:   mails with no keyword match are asked to a cheap LLM (fewer misses;
#           requires OPENROUTER_API_KEY, free tier is ~50 requests/day).
PREFILTER_MODE=keywords
PREFILTER_MODEL=openai/gpt-oss-20b:free
# A mail passes to the LLM if one of these appears in subject/body (comma-separated, lowercase).
FILTER_KEYWORDS=application,başvuru,interview,mülakat,offer,teklif,position,pozisyon,recruit,candidate,aday,job,thank you for applying,we received your application
# Mails from these domains are dropped outright (comma-separated).
FILTER_EXCLUDE_DOMAINS=facebookmail.com,notifications.google.com

# --- Web UI ---
WEB_ADDR=:8080
# HTTP Basic Auth. Enabled when BOTH are set; the UI is unprotected otherwise.
# If you expose it to the internet on a VPS, ALWAYS set these.
WEB_USER=
WEB_PASS=
